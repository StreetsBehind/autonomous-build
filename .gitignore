# OS / editor
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Local-only formula test scratch (formulas get dry-run-cooked in throwaway projects)
scratch/
*.local/

# NOTE: .beads/ is intentionally NOT ignored. autonomous-build itself runs on beads
# (workflow-improvements epic + retro-filed tasks). The Dolt backend + JSONL are
# designed to be committed.

# Logs from loop runs
loop-*.log

# Claude Code local hook settings (regenerate per machine via `bd setup claude --project`)
.claude/settings.local.json

# Retro temp files (created during /retro analysis, not the final reports)
.retro-tmp/

# Transient bd ready dump (some skills pipe `bd ready --json` here mid-run)
ready.json

# Stray bd/dolt runtime working files when bd runs with cwd at the repo ROOT
# (the real, committed store lives under .beads/ — these root copies are cruft).
# Anchored with a leading slash so .beads/dolt/ etc. are unaffected.
/dolt/
/dolt-access.lock
/ephemeral.sqlite3

.bd-batch-state.json

# Build / eval output (jankurai receipts, vision-eval results — regenerated, not source)
/target/

# Claude Code runtime locks (per-machine, not source)
.claude/scheduled_tasks.lock
